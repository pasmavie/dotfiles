[user]
    name = Gio
    email = kayaularge@gmail.com

[push]
    autoSetupRemote = true
    default = current

[pull]
    rebase = true

[init]
    defaultBranch = main

[core]
    pager = delta
    editor = nvim
    excludesFile = ~/.config/git/ignore

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    line-numbers = true
    side-by-side = true
    syntax-theme = Catppuccin Mocha

[merge]
    conflictstyle = zdiff3

[diff]
    algorithm = histogram
    colorMoved = default

[rerere]
    enabled = true

[fetch]
    prune = true

[alias]
    s = status --short
    l = log --oneline -20
    lg = log --graph --oneline --decorate --all
    d = diff
    ds = diff --staged
    co = checkout
    cb = checkout -b
    amend = commit --amend --no-edit
    undo = reset --soft HEAD~1
    wip = !git add -A && git commit -m 'wip'

[advice]
    addIgnoredFile = false
