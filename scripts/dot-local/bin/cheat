#!/usr/bin/env bash

# Colors (Catppuccin Mocha)
R='\033[0m'
B='\033[1m'
DIM='\033[2m'
PEACH='\033[38;2;250;179;135m'
GREEN='\033[38;2;166;227;161m'
BLUE='\033[38;2;137;180;250m'
YELLOW='\033[38;2;249;226;175m'
MAUVE='\033[38;2;203;166;247m'
TEXT='\033[38;2;205;214;244m'
SURFACE='\033[38;2;69;71;90m'

header() { echo -e "\n${B}${PEACH}━━━ $1 ━━━${R}"; }
key() { printf "  ${GREEN}%-28s${R} ${TEXT}%s${R}\n" "$1" "$2"; }
alias_line() { printf "  ${BLUE}%-28s${R} ${TEXT}%s${R}\n" "$1" "$2"; }
divider() { echo -e "${SURFACE}  ─────────────────────────────────────────${R}"; }

echo -e "${B}${MAUVE}"
echo '  ╔══════════════════════════════════════╗'
echo '  ║        Dotfiles v2 Cheatsheet        ║'
echo '  ╚══════════════════════════════════════╝'
echo -e "${R}"

header "AeroSpace  ·  alt = modifier"
key "alt + h/j/k/l" "Focus window"
key "alt + shift + h/j/k/l" "Move window"
key "alt + 1/2/3" "Switch workspace"
key "alt + shift + 1/2/3" "Send window to workspace"
key "alt + f" "Fullscreen"
key "alt + shift + space" "Float / tile toggle"
key "alt + r" "Rotate layout"
key "alt + shift + r" "Resize mode (hjkl, esc)"
key "alt + shift + b" "Balance sizes"
key "alt + enter" "Open Ghostty"

header "tmux  ·  C-b = prefix"
key "C-h/j/k/l" "Navigate panes (no prefix)"
key "C-b c" "New window"
key "C-b \"" "Split horizontal"
key "C-b %" "Split vertical"
key "C-b H/J/K/L" "Resize pane"
key "C-b S" "Join pane"
key "t0 / t1" "Attach session (alias)"

header "Shell  ·  modern CLI"
alias_line "ls / ll / lt" "eza (icons, tree)"
alias_line "cat" "bat (syntax highlight)"
alias_line "grep" "rg (ripgrep)"
alias_line "find" "fd"
alias_line "z <dir>" "zoxide (smart cd)"
alias_line "z fo ba" "multi-fragment match"
alias_line "zi <dir>" "zoxide interactive"
divider
key "ctrl + r" "Fuzzy history (atuin)"
key "ctrl + t" "Fuzzy file finder (fzf)"
key "alt + c" "Fuzzy cd (fzf)"

header "LazyVim  ·  space = leader"
key "i / a" "Insert before / after cursor"
key "o / O" "New line below / above"
key "v / V" "Visual char / line select"
key "jj / Esc" "Back to Normal mode"
divider
key "h/j/k/l" "Left / down / up / right"
key "w / b" "Word forward / back"
key "gg / G" "Top / bottom of file"
key "C-d / C-u" "Half page down / up"
key "B / E" "Start / end of line"
divider
key "u / C-r" "Undo / redo"
key "." "Repeat last change"
key "yy / p / P" "Yank line / paste below / above"
key "d" "Delete (no yank)"
key "ciw / ci\" / ci(" "Change in word / string / parens"
key "gcc" "Toggle comment"
divider
key "C-n / C-p" "Next / prev buffer"
key "C-q" "Close buffer, keep window"
key "C-y" "Yank to clipboard (visual)"
key "<leader>p" "Paste without yank (visual)"
divider
key "<leader>ff" "Find file"
key "<leader>sg" "Live grep"
key "<leader>t" "File tree"
key "<leader>," "Buffer list"
key "gd / gr / K" "Go to def / refs / hover"
key "<leader>ca / cr / cf" "Code action / rename / format"
key "<leader>gg" "Lazygit"
key "<leader>l" "Lazy plugin manager"
key "<leader>" "Wait → show all keys"

header "Git  ·  delta diffs"
alias_line "git s" "Status (short)"
alias_line "git l" "Log (oneline, 20)"
alias_line "git lg" "Log graph"
alias_line "git d / git ds" "Diff / diff staged"
alias_line "git co / git cb" "Checkout / new branch"
alias_line "git undo" "Reset soft HEAD~1"
alias_line "git wip" "Add all + commit 'wip'"

header "Modifier Map"
echo -e "  ${YELLOW}alt${R}          → AeroSpace (windows)"
echo -e "  ${YELLOW}C-b${R}          → tmux (multiplexer)"
echo -e "  ${YELLOW}C-h/j/k/l${R}   → vim-tmux-navigator"
echo -e "  ${YELLOW}space${R}        → LazyVim (editor)"
echo -e "  ${YELLOW}super${R}        → Ghostty / macOS"
echo ""
